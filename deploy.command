#!/bin/bash
# ==========================================================
#  원클릭 배포 스크립트
#  이 파일을 더블클릭하면:
#    1) 변경된 모든 파일을 GitHub에 자동 저장(commit + push)
#    2) Vercel이 자동으로 새 버전을 퍼블리싱
#  터미널 명령으로 실행하려면:  npm run deploy
# ==========================================================

# 스크립트가 있는 폴더로 이동 (더블클릭 실행 대비)
cd "$(dirname "$0")" || exit 1

echo "=================================================="
echo "  🚀 GitHub 저장 + Vercel 배포 시작"
echo "=================================================="
echo ""

# 변경사항이 있는지 확인
if [ -z "$(git status --porcelain)" ]; then
  echo "✅ 변경된 내용이 없습니다. 배포할 게 없어요."
  echo ""
  read -n 1 -s -r -p "아무 키나 누르면 창이 닫힙니다..."
  exit 0
fi

# 변경된 파일 목록 보여주기
echo "📝 변경된 파일:"
git status --short
echo ""

# 커밋 메시지: 인자로 받거나, 없으면 날짜/시간 자동 생성
if [ -n "$1" ]; then
  MSG="$1"
else
  MSG="업데이트 $(date '+%Y-%m-%d %H:%M')"
fi

echo "💾 GitHub에 저장 중... (메시지: $MSG)"
git add -A
git commit -m "$MSG" || { echo "❌ 커밋 실패"; read -n 1 -s -r -p "키를 누르세요..."; exit 1; }

echo ""
echo "☁️  GitHub로 업로드 중..."
if git push; then
  echo ""
  echo "=================================================="
  echo "  ✅ 완료! GitHub 저장 + Vercel 배포가 시작됐어요."
  echo "  잠시(1~2분) 후 사이트에 반영됩니다."
  echo "=================================================="
else
  echo ""
  echo "❌ 업로드 실패. 인터넷 연결 또는 GitHub 로그인을 확인하세요."
fi

echo ""
read -n 1 -s -r -p "아무 키나 누르면 창이 닫힙니다..."
